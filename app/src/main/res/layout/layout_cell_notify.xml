<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_height="wrap_content"
    android:layout_width="match_parent"
    >

  <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:padding="14.0dp"
      >

    <TextView
        android:id="@+id/cell_notify_index"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="32.0dp"
        android:textColor="@color/ct_1"
        android:textSize="15.0dp"
        android:lineSpacingMultiplier="1.3"
        tools:ignore="SpUsage"
        />

    <View
        android:layout_width="14.0dp"
        android:layout_height="0.0dp"
        />

    <LinearLayout
        android:layout_height="wrap_content"
        android:layout_width="0.0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        >

      <TextView
          android:id="@+id/cell_notify_content"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:textColor="@color/ct_1"
          android:textSize="15.0dp"
          android:text="@string/cell_notify"
          tools:ignore="SpUsage"
          />

      <View
          android:layout_width="0.0dp"
          android:layout_height="8.0dp"
          />

      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:gravity="center_vertical"
          android:orientation="horizontal"
          >

        <TextView
            android:id="@+id/cell_notify_num"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="42.0dp"
            android:minHeight="42.0dp"
            android:textColor="@color/ct_2"
            android:gravity="center"
            android:textSize="13.0dp"
            android:background="@drawable/bg_play"
            tools:ignore="SpUsage"
            />

        <View
            android:layout_width="0.0dp"
            android:layout_height="0.0dp"
            android:layout_weight="1"
            />

        <TextView
            android:id="@+id/cell_notify_play"
            android:layout_width="64.0dp"
            android:layout_height="64.0dp"
            android:textColor="@color/ct_1"
            android:textSize="20.0dp"
            android:text="@string/play"
            android:gravity="center"
            android:background="@drawable/bg_play"
            tools:ignore="SpUsage"
            />

      </LinearLayout>

    </LinearLayout>

  </LinearLayout>

  <View
      android:layout_width="match_parent"
      android:layout_height="0.4dp"
      android:background="@color/line"
      android:layout_gravity="bottom"
      />

</FrameLayout>